# ========================================
# 辰栈后端环境变量配置示例
# ========================================
# 注意：此文件为配置模板，不包含真实敏感信息
#
# 使用说明：
# 1. 复制此文件为 .env：cp .env.example .env
# 2. 根据您的实际环境修改下面的配置
# 3. 生产环境请务必修改所有默认密码和密钥
#
# ========================================

# ========================================
# 数据库配置 (MySQL)
# ========================================
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_DATABASE=chen_stack
MYSQL_USERNAME=root
MYSQL_PASSWORD=root

# ========================================
# Redis 配置
# ========================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_USERNAME=
REDIS_PASSWORD=

# ========================================
# 邮件配置 (QQ 邮箱)
# ========================================
MAIL_USERNAME=your-email@qq.com
MAIL_PASSWORD=your-email-password

# ========================================
# RabbitMQ 配置
# ========================================
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USERNAME=guest
RABBITMQ_PASSWORD=guest
# 本地不启动 RabbitMQ 时可改为 false，避免监听器循环重连刷日志
RABBITMQ_LISTENER_AUTO_STARTUP=true

# ========================================
# AI 服务配置 (DeepSeek API)
# ========================================
# 获取方式：https://platform.deepseek.com/api_keys
SPRING_AI_OPENAI_API_KEY=your-deepseek-api-key
SPRING_AI_OPENAI_BASE_URL=https://api.deepseek.com
SPRING_AI_OPENAI_CHAT_OPTIONS_MODEL=deepseek-chat

# ========================================
# MinIO 配置
# ========================================
MINIO_ENDPOINT=http://localhost:9000
MINIO_PUBLIC_POINT=http://localhost:9000
MINIO_ACCESS_KEY=minio
MINIO_SECRET_KEY=minio123456

# ========================================
# 前端地址
# ========================================
FRONTEND_USER_HOST=http://localhost:7000/
FRONTEND_ADMIN_HOST=http://localhost:8000/

# ========================================
# 阿里云内容审核
# ========================================
ALIYUN_ACCESS_KEY_ID=your-access-key-id
ALIYUN_ACCESS_KEY_SECRET=your-access-key-secret

# ========================================
# 辰栈业务配置
# ========================================
# JWT 密钥 - 生产环境请使用复杂随机字符串
CHEN_STACK_JWT_SECRET=your_jwt_secret_key
# 限流开关，压力测试时设为 false
CHEN_STACK_RATE_LIMIT_ENABLED=true
# 自动审核配置
CHEN_STACK_PHOTO_AUTO_AUDIT=false
CHEN_STACK_ARTICLE_AUTO_AUDIT=false
CHEN_STACK_COMMENT_AUTO_AUDIT=false
